generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "mongodb"
  url      = env("DATABASE_URL")
}

model User {
  id       String @id @default(auto()) @map("_id") @db.ObjectId
  email    String @unique
  name     String
  password String
  // Um usuário pode ter vários jogos na lista dele
  games    Game[] 
}

model Game {
  id        String   @id @default(auto()) @map("_id") @db.ObjectId
  title     String
  status    String
  genre     String?
  rating    Int?
  platform  String?
  cover     String?  // <--- ADICIONE ESTA LINHA AQUI!
  
  createdAt DateTime @default(now())
  
  // Suas relações com o User continuam iguais aqui embaixo...
  userId    String   @db.ObjectId
  user      User     @relation(fields: [userId], references: [id])
}